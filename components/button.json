{
  "$schema"   : "../schemas/component.json",
  "modifiers" : {
    "Variant" : { "default": "primary", "values": ["secondary", "destructive"            ] },
    "Emphasis": { "default": "bold",    "values": ["subtle",    "minimal"                ] },
    "Scale"   : { "default": "md",      "values": ["xs",        "sm",          "lg", "xl"] }
  },
  "name"      : "FluidButton",
  "properties": {
    "BorderColor": {
      "*"          : "$border/brand/strong",
      "destructive": "$border/status/danger/strong",
      "secondary"  : "$border/neutral/strong"
    },
    "BorderStyle": "BorderStyle.Solid",
    "BorderThickness": { "*": {"*": 0, "subtle": 1} },
    "Color": {
      "*"          : {"bold": "$text/neutral/inverse", "*": "$text/brand/primary"},
      "destructive": {"bold": "$text/neutral/inverse", "*": "$text/status/danger/primary"},
      "secondary"  : "$text/neutral/primary"
    },
    "DisabledBorderColor": {
      "*"          : "$border/brand/strong.35",
      "destructive": "$border/status/danger/strong",
      "secondary"  : "$border/neutral/strong.35"
    },
    "DisabledColor": {
      "*"          : {"bold": "$text/neutral/inverse.35", "*": "$text/brand/primary.35"},
      "destructive": {"bold": "$text/neutral/inverse.35", "*": "$text/status/danger/primary.35"},
      "secondary"  : "$text/neutral/primary.35"
    },
    "DisabledFill": {
      "*"          : {"bold": "$background/brand/solid.35", "*": "$background/brand/primary/translucent/default.35"},
      "destructive": {
        "bold": "$background/status/danger/solid.35",
        "*"   : "$background/neutral/primary/translucent/default.35"
      },
      "secondary"  : {
        "bold": "$background/neutral/tertiary/translucent/default.35",
        "*"   : "$background/neutral/primary/translucent/default.35"
      }
    },
    "Fill": {
      "*"          : {"bold": "$background/brand/solid", "*": "$background/brand/primary/translucent/default"},
      "destructive": {
        "bold": "$background/status/danger/solid",
        "*"   : "$background/neutral/primary/translucent/default"
      },
      "secondary"  : {
        "bold": "$background/neutral/tertiary/translucent/default",
        "*"   : "$background/neutral/primary/translucent/default"
      }
    },
    "FocusedBorderColor": "$border/brand/strong",
    "FocusedBorderThickness": 2,
    "Font": "$font-family/default",
    "HoverBorderColor": {
      "*"          : "$border/brand/strong/hovered",
      "destructive": "$border/status/danger/strong/hovered",
      "secondary"  : "$border/neutral/strong/hovered"
    },
    "HoverColor": {
      "*"          : {"bold": "$text/neutral/inverse", "*": "$text/brand/primary/hovered"},
      "destructive": {"bold": "$text/neutral/inverse", "*": "$text/status/danger/primary/hovered"},
      "secondary"  : "$text/neutral/primary"
    },
    "HoverFill": {
      "*"          : {"bold": "$background/brand/solid/hovered", "*": "$background/brand/primary/translucent/hovered"},
      "destructive": {
        "bold": "$background/status/danger/solid/hovered",
        "*"   : "$background/status/danger/primary/translucent/hovered"
      },
      "secondary"  : {
        "bold": "$background/neutral/tertiary/translucent/hovered",
        "*"   : "$background/neutral/primary/translucent/hovered"
      }
    },
    "PaddingBottom": {
      "*": {
        "*": {
          "xs": "$semantic-size/spacing/4",
          "sm": "$semantic-size/spacing/8",
          "*" : "$semantic-size/spacing/8",
          "lg": "$semantic-size/spacing/12",
          "xl": "$semantic-size/spacing/16"
        }
      }
    },
    "PaddingTop": {
      "*": {
        "*": {
          "xs": "$semantic-size/spacing/4",
          "sm": "$semantic-size/spacing/8",
          "*" : "$semantic-size/spacing/8",
          "lg": "$semantic-size/spacing/12",
          "xl": "$semantic-size/spacing/16"
        }
      }
    },
    "PaddingLeft": {
      "*": {
        "*": {
          "xs": "$semantic-size/spacing/16",
          "sm": "$semantic-size/spacing/24",
          "*" : "$semantic-size/spacing/32",
          "lg": "$semantic-size/spacing/48",
          "xl": "$semantic-size/spacing/48"
        }
      }
    },
    "PaddingRight": {
      "*": {
        "*": {
          "xs": "$semantic-size/spacing/16",
          "sm": "$semantic-size/spacing/24",
          "*" : "$semantic-size/spacing/32",
          "lg": "$semantic-size/spacing/48",
          "xl": "$semantic-size/spacing/48"
        }
      }
    },
    "PressedBorderColor": {
      "*"          : "$border/brand/strong/pressed",
      "destructive": "$border/status/danger/strong/pressed",
      "secondary"  : "$border/neutral/strong/pressed"
    },
    "PressedColor": {
      "*"          : {"bold": "$text/neutral/inverse", "*": "$text/brand/primary/pressed"},
      "destructive": {"bold": "$text/neutral/inverse", "*": "$text/status/danger/primary/pressed"},
      "secondary"  : "$text/neutral/primary"
    },
    "PressedFill": {
      "*"          : {"bold": "$background/brand/solid/pressed", "*": "$background/brand/primary/translucent/pressed"},
      "destructive": {
        "bold": "$background/status/danger/solid/pressed",
        "*"   : "$background/status/danger/primary/translucent/pressed"
      },
      "secondary"  : {
        "bold": "$background/neutral/tertiary/translucent/pressed",
        "*"   : "$background/neutral/primary/translucent/pressed"
      }
    },
    "RadiusBottomLeft": 0,
    "RadiusBottomRight": 0,
    "RadiusTopLeft": 0,
    "RadiusTopRight": 0,
    "Size": {
      "*": {
        "*": {
          "xs": "$semantic-font-size/text/xs/desktop",
          "sm": "$semantic-font-size/text/xs/desktop",
          "*" : "$semantic-font-size/text/sm/desktop",
          "lg": "$semantic-font-size/text/md/desktop",
          "xl": "$semantic-font-size/text/lg/desktop"
        }
      }
    }
  }
}
